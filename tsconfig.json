{
  "compilerOptions": {
    "target": "es2023",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "outDir": "dist",
    "skipLibCheck": true
  },
  "include": ["src"],
  "comment": "The desktop app (src/desktop) is built by electron-vite, which has its own DOM/Electron types; exclude it here so the engine typecheck stays focused and clean.",
  "exclude": ["src/desktop"]
}
